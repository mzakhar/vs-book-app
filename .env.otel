VS_BOOK_APP_SERVICE_NAME=vs-book-app
# OTEL_SERVICE_NAME is intentionally absent. VS_BOOK_APP_SERVICE_NAME prevents
# ambient agent telemetry settings from changing this app's identity.
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf
OTEL_TRACES_SAMPLER=always_on
OTEL_SEMCONV_STABILITY_OPT_IN=http
OTEL_RESOURCE_ATTRIBUTES=deployment.environment.name=development,service.namespace=zakharhome
